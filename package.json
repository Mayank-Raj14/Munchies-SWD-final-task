{
  "name": "munchies",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack hostel marketplace for student-run food stores.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace backend",
    "prisma:studio": "npm run prisma:studio --workspace backend"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
